// Cerebro - Gamified Learning Platform
// Users submit course notes -> AI generates GTA-style missions -> Complete to birth virtual agents

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Curriculum {
  id          String   @id @default(cuid())
  name        String
  domain      String   @unique
  description String
  icon        String
  color       String
  xp          Int      @default(0)
  level       Int      @default(1)
  isCustom    Boolean  @default(false)
  language    String   @default("python")
  // DataCamp sync metadata (null for non-DataCamp curricula)
  datacampUrl        String?
  datacampProgress   Int      @default(0) // 0-100 percentage completed on DataCamp
  completedCourses   String   @default("[]") // JSON array of {title, url, completedAt}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  missions    Mission[]
  agent       Agent?
}

model Mission {
  id            String   @id @default(cuid())
  curriculumId  String
  curriculum    Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  title         String
  briefing      String   // GTA-style narrative briefing
  objectives    String   // JSON array of strings
  starterCode   String   @default("")
  hint          String   @default("")
  difficulty    String   @default("rookie") // rookie | pro | elite
  xp            Int      @default(100)
  status        String   @default("active") // active | completed
  sourceContent String   @default("") // The course content that generated this mission
  language      String   @default("python") // The language the user must write code in
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  submissions   MissionSubmission[]
}

model MissionSubmission {
  id          String   @id @default(cuid())
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  code        String
  feedback    String   @default("")
  passed      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Agent {
  id            String   @id @default(cuid())
  curriculumId  String   @unique
  curriculum    Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  name          String
  persona       String   // AI system prompt that defines the agent's voice and knowledge
  skills        String   // JSON array of skills mastered
  totalXp       Int      @default(0)
  level         Int      @default(1)
  status        String   @default("idle") // idle | working | interviewing | relaxing
  activity      String   @default("En attente d'instructions") // human-readable current activity
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  conversations AgentConversation[]
}

model AgentConversation {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role        String   // "user" | "agent"
  content     String
  createdAt   DateTime @default(now())
}

// Quêtes quotidiennes auto-générées pour le spaced retrieval
// Une nouvelle quête est créée chaque jour, basée sur les missions accomplies récentes
model DailyQuest {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   // "review" | "challenge" | "streak" | "new_mission"
  xpReward    Int      @default(50)
  status      String   @default("pending") // "pending" | "completed"
  // Link to a mission or agent if relevant
  missionId   String?
  agentId     String?
  // Date (day granularity - one quest set per day)
  questDate   DateTime
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// Achievements (badges) débloqués par l'utilisateur
// Détection automatique basée sur les critères (missionsCount, streakDays, etc.)
model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique // "first_mission", "week_streak", "first_agent", etc.
  title       String
  description String
  icon        String   // emoji or icon name
  color       String   // hex color
  category    String   // "missions" | "streak" | "agents" | "exploration" | "mastery"
  xpReward    Int      @default(50)
  unlockedAt  DateTime?
  createdAt   DateTime @default(now())
}

